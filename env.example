# ─── Twitch App Credentials ───────────────────────────────────────────────────
# Get these from https://dev.twitch.tv/console/apps
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# ─── Your Twitch Channel ──────────────────────────────────────────────────────
TWITCH_BROADCASTER_LOGIN=your_twitch_username_here

# ─── OAuth Token (generated by auth-helper.js) ────────────────────────────────
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=

# ─── EventSub Webhook ─────────────────────────────────────────────────────────
# Your publicly reachable URL (use ngrok for local dev)
# Example: https://abc123.ngrok.io
WEBHOOK_PUBLIC_URL=https://your-ngrok-url-here.ngrok.io
WEBHOOK_SECRET=make_up_a_random_secret_string_here

# ─── Server Settings ──────────────────────────────────────────────────────────
HTTP_PORT=3000
WS_PORT=3001

# ─── Display Settings ─────────────────────────────────────────────────────────
# How often (ms) to refresh follower/sub counts from Twitch REST API
POLL_INTERVAL_MS=60000

# How long (ms) each regular message stays on screen before rotating
MESSAGE_DISPLAY_MS=8000

# Your social links shown in rotation
YOUTUBE_URL=youtube.com/yourchannel
TIKTOK_URL=tiktok.com/@yourhandle
